{
  "name": "functions",
  "scripts": {
    "test": "jest --passWithNoTests --runInBand",
    "test:watch": "jest --watch",
    "lint": "eslint --fix ./",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "clean": "gts clean",
    "compile": "tsc",
    "fix": "gts fix"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google-cloud/secret-manager": "^6.2.0",
    "axios": "^1.18.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "csv": "^6.6.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "helmet": "^8.3.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/compression": "~1.8.1",
    "@types/cors": "^2.8.19",
    "@types/eslint": "^9.6.1",
    "@types/express": "~5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.4",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.0.2",
    "firebase-functions-test": "^3.5.0",
    "globals": "^17.7.0",
    "gts": "^7.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "private": true,
  "allowScripts": {
    "@firebase/util@1.15.1": true,
    "fsevents@2.3.3": true,
    "protobufjs@7.6.4": true,
    "unrs-resolver@1.12.2": true
  }
}
